# pyenv
#   For a library or app, you might want to share your .python-version.
#   Documented here: https://github.com/pyenv/pyenv/blob/master/COMMANDS.md#pyenv-version-file
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used in a library, you can skip it.
#   https://pipenv.pypa.io/en/latest/advanced/#pipfile-vs-setup-py
#Pipfile.lock

# poetry
#   Similar to Pipenv, poetry.lock contains exact signatures of dependencies.
#   https://python-poetry.org/docs/basic-usage/#commit-your-poetrylock-file-to-version-control
#poetry.lock

# pdm
#   Similar to Pipenv and Poetry, pdm.lock contains exact signatures of dependencies.
#pdm.lock
#   pdm project configuration
.pdm-python.path
.pdm-build/

# PEP 582; used by e.g. github.com/lincolnloop/layman and pdm
__pypackages__/

